<style>
    body {
        background-color: #0a0a0a;
        margin: 0;
        padding: 0;
        font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
        display: flex; 
        justify-content: flex-start; 
        align-items: flex-end; 
        min-height: 100vh; 
    }

    .form-container {
        width: 100%;
        max-width: 600px; 
        display: flex;
        flex-direction: column; 
        align-items: center; 
        padding: 20px;

        margin-left: 450px;  
        margin-top: 0px;   
        }

    .form-title {
        color: #ffffff;
        font-weight: 900;
        font-size: 64px;
        text-transform: uppercase;
        letter-spacing: 12px;
        margin-bottom: 40px;
        text-align: center;
    }

    form {
        width: 100%;
        background-color: #111315;
        padding: 40px;
        border: 1px solid #222;
        border-radius: 4px;
        box-sizing: border-box;
    }

    fieldset {
        border: none;
        padding: 0;
        margin: 0;
    }

    legend {
        color: #ffffff;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: 14px;
        margin-bottom: 30px;
        border-bottom: 2px solid #ffffff;
        padding-bottom: 15px;
        width: 100%;
        text-align: left;
    }

    label {
        display: block;
        color: #666; 
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 2px;
        margin-bottom: 8px;
        margin-top: 20px;
    }

    input, select {
        width: 100%;
        padding: 18px;
        background-color: #1a1c1e;
        border: 1px solid #333;
        color: #ffffff;
        font-size: 16px;
        font-weight: 500;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.2s ease;
    }

    input:focus, select:focus {
        border-color: #fff;
        outline: none;
    }

    select {
        cursor: pointer;
        padding: 8px 12px;
    }

    select option {
        background-color: #1a1c1e;
        color: #fff;
    }
    

    input[type="submit"] {
        width: 100%;
        margin-top: 40px;
        padding: 22px;
        background-color: #ffffff;
        color: #000000;
        border: none;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 5px;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    input[type="submit"]:hover {
        background-color: #e0e0e0;
        transform: scale(1.02);
    }

    .back-btn {
        margin-top: 30px;
        color: #444;
        text-decoration: none;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 2px;
        font-weight: 700;
        transition: color 0.2s;
    }

    .back-btn:hover {
        color: #ffffff;
    }
</style>

<div class="form-container">
    <h1 class="form-title">{{#if isEdit}}EDIT CAT{{else}}CAT REG{{/if}}</h1>

    <form method="POST" action="{{#if isEdit}}/cats/update/{{cat.id}}{{else}}/cats/add{{/if}}">
        <fieldset style="border:none; padding:0; margin:0;">
            <legend style="color:#fff; font-weight:800; text-transform:uppercase; border-bottom:2px solid #fff; width:100%; padding-bottom:15px; margin-bottom:30px;">
                {{#if isEdit}}Update information for {{cat.name}}{{else}}Information about the cat{{/if}}
            </legend>
    <label>
      Cat Name
      <input
        name="cat_name"
        placeholder="e.g. Luna"
        value="{{cat.name}}"
      />
    </label>
    <label>
      Breed 
      <input
        name = "breed"
        placeholder="e.g. Siamese"
        value="{{cat.breed}}"
        />
    </label>
    <label>
       Age (years)
        <input
        name="age"
        placeholder="2"
        value="{{cat.age_years}}"
      />
    </label>
    <label>
        Weight (kg) 
        <input
        name="weight"
        placeholder="4.5"
        value="{{cat.weight_kg}}"
        />
    </label>
    <label>
        Favorite food
        <input
        name="favorite_food"
        placeholder="e.g. korm"
        value="{{cat.favorite_food}}"
        />
    </label>
    <label>
        Has Microchip
        <select name="microchip", id="microchip">
        <option value="true" {{#if cat.has_microchip}}selected{{/if}}>yes</option>
        <option value="false" {{#unless cat.has_microchip}}selected{{/unless}}>no</option>
        </select>
    </label>
    <label>
        Owner Contact (Phone)
        <input
        name="owner_contact"
        placeholder="+123456789"
        value="{{cat.owner_contact}}"
        />
    </label>
    <label>
        Character Notes
        <input
        name="character_notes"
        placeholder="e.g. Very friendly"
        value="{{cat.character_notes}}"
        />
    </label>
  </fieldset>
        <input type="submit" value="{{#if isEdit}}Save Changes{{else}}Register Cat{{/if}}" />
    </form>
    
    <a href="/cats" class="back-btn">← Back to table</a>
</div>