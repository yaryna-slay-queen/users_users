<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-body: #0b0e14;      
        --bg-card: #151921;      
        --bg-input: #1c222d;     
        --text-main: #ffffff;    
        --text-muted: #718096;   
        --accent-blue: #3b82f6;  
        --border: #2d3748;       
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        color: var(--text-main);
        padding: 80px 20px;
        -webkit-font-smoothing: antialiased;
    }

    h3 {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 25px;
        text-align: center;
        letter-spacing: -0.02em;
    }

    .edit-container {
        background-color: var(--bg-card);
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        max-width: 400px;
        margin: 0 auto;
        border: 1px solid var(--border);
    }

    label { 
        display: block; 
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 20px;
        margin-bottom: 8px;
    }

    input { 
        width: 100%; 
        padding: 14px 16px; 
        margin-top: 5px; 
        background-color: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: white;
        font-size: 15px;
        font-family: inherit;
        box-sizing: border-box; 
        transition: all 0.2s ease;
    }

    input:focus {
        outline: none;
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    }

    .btn-save {
        margin-top: 35px; 
        width: 100%; 
        padding: 16px;
        background-color: var(--accent-blue); 
        color: white;
        border: none; 
        border-radius: 12px; 
        cursor: pointer; 
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
        filter: brightness(1.1);
    }

    .back-link { 
        display: block; 
        margin-top: 25px; 
        text-align: center; 
        color: var(--text-muted); 
        text-decoration: none; 
        font-size: 14px;
        font-weight: 600;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: white;
    }
</style>

<div class="edit-container">
    <h3>Edit Movie</h3>
    
    <form action="/movies/edit/{{movie.id}}" method="POST">
        <label>Movie Title</label>
        <input type="text" name="title" value="{{movie.title}}" required>

        <label>Director</label>
        <input type="text" name="director" value="{{movie.director}}" required>

        <label>Release Year</label>
        <input type="number" name="release_year" value="{{movie.release_year}}" required>

        <label>Rating</label>
        <input type="number" step="0.1" name="rating" value="{{movie.rating}}" required>

        <button type="submit" class="btn-save">Update Movie</button>
    </form>

    <a href="/movies" class="back-link">← Cancel and go back</a>
</div>