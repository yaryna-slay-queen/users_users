<style>
  /*BACKGROUND*/
  body {
    background-color: #fc85bc;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    margin: 0;
  }

  /*STYLES. WHITE BOX*/
  .main-container {
    background: rgba(250, 159, 209, 0.884);
    padding: 30px;
    border-radius: 40px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    max-width: 500px;
    width: 90%;
    margin-left: auto;
    margin-right: auto;
    display: block;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /*STYLES. PINK BUTTONS*/
  .btn-pink {
    background-color: rgb(233, 75, 167);
    border: none;
    border-radius: 10px;
    padding: 10px 20px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    display: inline-block;
    text-decoration: none;
    margin-bottom: 20px;
    color: #ffffff !important;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  .btn-pink:hover {
    background-color: rgb(220, 110, 180);
  }

  /*STYLE. ERROR MESSAGE*/
  .error-box {
    background-color: #ff1289;
    color: white;
    padding: 15px;
    margin: 15px 0;
    border-radius: 10px;
    font-weight: bold;
    font-size: 1rem;
  }

  /*STYLE. INPUT AREA*/
  fieldset {
    border: none;
    padding: 0;
    margin-bottom: 20px;
    text-align: left;
  }

  label {
    display: block;
    margin-bottom: 10px;
    font-weight: bold;
    color: rgb(228, 23, 142);
  }

  input[type="text"],
  input[type="password"] {
    width: 100%;
    padding: 12px;
    border-radius: 10px;
    border: 2px solid rgb(233, 75, 167);
    box-sizing: border-box;
    font-size: 1rem;
    margin-top: 5px;
  }

  input:focus {
    border-color: rgb(242, 130, 208);
    outline: none;
  }

  /*STYLE. HIDING BUTTON*/
  .password-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .toggle-btn {
    position: absolute;
    right: 12px;
    top: calc(40% + 2.5px);
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.2rem;
    padding: 0;
    color: rgb(233, 75, 167);
  }

  /* STYLE. CAT IMAGES*/
  .cats-background-layer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
  }

  .cat-gif {
    position: absolute;
  }

  /*COORDINATES OF CATS*/
  #cat-left-top {
    width: 180px;
    top: 50px;
    left: 100px;
  }
  #cat-left-bottom {
    width: 180px;
    bottom: 90px;
    left: 80px;
  }
  #cat-right-top {
    width: 180px;
    top: 50px;
    right: 120px;
  }
  #cat-right-bottom {
    width: 300px;
    bottom: 30px;
    right: 30px;
  }
</style>

