{{! MAIN HBS CODE. ADDING BUTTONS AND SO ON. }}
<div class="main-container">
  <a href="/accounts" class="btn-pink">CANCEL</a>

  {{#if error}}
    <div class="error-box">
      {{error}}
    </div>
  {{/if}}

  <form method="POST" action="{{action}}">
    <fieldset>
      <label>
        Email
        <input
          type="text"
          name="email"
          placeholder="Enter email..."
          value="{{item.email}}"
          aria-required="true"
        />
      </label>

      <label>
        User Name
        <input
          type="text"
          name="user_name"
          placeholder="Enter username..."
          value="{{item.user_name}}"
          aria-required="true"
        />
      </label>
      <label>
        Password
        <div class="password-wrapper">
          <input
            type="password"
            name="password"
            id="password-input"
            placeholder="Enter password..."
            value="{{item.password}}"
            aria-required="true"
          />
          <button
            type="button"
            id="toggle-password"
            class="toggle-btn"
          >🙈</button>
        </div>
      </label>
    </fieldset>

    <input type="submit" value="SAVE" class="btn-pink" style="width: 100%;" />
  </form>
</div>

{{! SMALL HIDING-SHOWING BUTTON }}
<script>
  const toggleBtn = document.getElementById('toggle-password'); const
  passwordInput = document.getElementById('password-input');
  toggleBtn.addEventListener('click', () => { const isPassword =
  passwordInput.type === 'password'; passwordInput.type = isPassword ? 'text' :
  'password'; toggleBtn.textContent = isPassword ? '🙉' : '🙈'; });
</script>