<style>

    table td, table th {
    background-color: rgb(10, 10, 10);
    color: white;
    padding: 10px 10px; 
    border: 1px solid #ffffff; 
    }

</style>






<div style="position: absolute; top: 20px; left: 20px; background-color:black; border-radius: 50px;">
    <a href="/" style="
        display:inline-block;
        padding: 10px 20px;
        color: rgb(255, 255, 255); 
        text-decoration: none; 
        border-radius: 20px;
        font-weight: bold;
        font-family: sans-serif;
        box-shadow: 0px 0px 15px rgba(255, 255, 255, 1);
    ">←</a>
</div>

    
</button>
    <h1 style="margin-top: 150px; margin-bottom: 30px; color:rgb(255, 255, 255);">GAMES LIST</h1>
        <table style="background-color:aliceblue; width: 1000px; min-width: 600px; " >
            <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Name</th>
                <th scope="col">Mode</th>
                <th scope="col">Cost</th>
                <th style="width: 100px"; scope="col">Created at</th>
                <th style="width: 80px"></th>
                <th style="width: 80px"></th>
            </tr>
            </thead>
            <tbody>
            {{#each games}}
                <tr>
                    <th scope="row">{{this.id}}</th>
                    <td>{{this.game_name}}</td>
                    <td>{{this.game_mode}}</td>
                    <td>{{this.cost}}</td>
                    <td>{{this.created_at}}</td>



                    <td><a style="
                    color:rgb(0, 200, 200); 
                    font-weight: bold; 
                    font-family: sans-serif; 
                    padding: 8px 12px;
                    " 
                    href="/games/update/{{this.id}}">Edit</a></td> 
                    

                    <td><a style="
                    color:rgb(255, 0, 0); 
                    font-weight: bold; 
                    font-family: sans-serif; 
                    padding: 8px 12px;
                    " 
                    href="/games/delete/{{this.id}}">Delete</a></td>


                </tr>
            {{/each}}
            </tbody>
        </table>

        <div style="display: inline-block; margin-top: 10px;"
            ><a style="
                color:rgb(0, 255, 0); 
                font-weight: bold; 
                font-family: sans-serif; 
                background-color:rgb(0, 100, 0); 
                border-radius: 20px; 
                padding: 10px 14px;
                box-shadow: 0px 0px 15px rgba(0, 255, 0, 1);
                " 
            href="/games/create">ADD</a>
        </div>

    </body>