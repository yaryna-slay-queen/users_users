<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-body: #0b0e14;      
        --bg-card: #151921;      
        --bg-input: #1c222d;     
        --text-main: #ffffff;    
        --text-muted: #718096;   
        --accent-green: #22c55e; 
        --accent-blue: #3b82f6;  
        --accent-red: #ef4444;   
        --border: #2d3748;       
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        color: var(--text-main);
        padding: 40px 20px 60px;
        max-width: 1100px;
        margin: 0 auto;
        -webkit-font-smoothing: antialiased;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--text-main);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 30px;
        padding: 10px 18px;
        background-color: rgba(255, 255, 255, 0.03); 
        border: 1px solid var(--border);
        border-radius: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-back:hover {
        background-color: rgba(255, 255, 255, 0.08);
        border-color: var(--text-muted);
        transform: translateX(-4px); 
    }

    h3 {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 30px;
        letter-spacing: -0.02em;
    }

    .form-container {
        background-color: var(--bg-card);
        padding: 32px;
        border-radius: 16px; 
        box-shadow: 0 20px 50px rgba(0,0,0,0.6); 
        margin-bottom: 50px;
        width: 340px;
        border: 1px solid var(--border);
    }

    .form-container label {
        display: block;
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 20px;
        margin-bottom: 8px;
    }

    .form-container input {
        width: 100%;
        padding: 12px 16px;
        background-color: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: white;
        font-size: 15px;
        font-family: inherit;
        box-sizing: border-box; 
    }

    .form-container button {
        margin-top: 30px;
        width: 100%;
        padding: 14px;
        background-color: var(--accent-green); 
        color: #052e16; 
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 800;
        text-transform: uppercase;
        transition: all 0.2s ease;
    }

    table {
        width: 100%;
        border-collapse: separate; 
        border-spacing: 0;
        background-color: var(--bg-card);
        border-radius: 16px;
        overflow: hidden; 
        border: 1px solid var(--border);
    }

    th {
        background-color: rgba(255, 255, 255, 0.02); 
        color: var(--text-muted);
        text-transform: uppercase; 
        font-size: 11px;
        font-weight: 800;
        padding: 20px;
        border-bottom: 1px solid var(--border);
        text-align: left;
    }

    th:nth-child(4), td:nth-child(4),
    th:nth-child(5), td:nth-child(5) {
        text-align: center;
    }

    th:last-child {
        text-align: center;
        padding-left: 40px;
    }

    td:last-child {
        text-align: right;
        width: 1%;
        white-space: nowrap;
        padding-right: 20px;
    }

    td {
        padding: 20px;
        border-bottom: 1px solid var(--border);
        font-size: 15px;
        vertical-align: middle;
    }

    .actions-cell {
        display: inline-flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn-edit, .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 36px; 
        min-width: 80px;
        padding: 0 16px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 13px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        box-sizing: border-box;
        line-height: 1;
        transition: 0.2s;
        margin: 0;
    }

    .btn-edit {
        background-color: rgba(59, 130, 246, 0.1);
        color: var(--accent-blue) !important;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .btn-edit:hover { background-color: var(--accent-blue); color: white !important; }

    .btn-delete {
        background-color: rgba(239, 68, 68, 0.1);
        color: var(--accent-red);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .btn-delete:hover { background-color: var(--accent-red); color: white; }
</style>

<a href="/" class="btn-back">←</a>

<h3>Add New Movie</h3>

<div class="form-container">
    <form action="/movies/create" method="POST">
        <label>Title</label>
        <input type="text" name="title" placeholder="e.g. Inception" required>
        
        <label>Director</label>
        <input type="text" name="director" placeholder="Christopher Nolan" required>
        
        <label>Year</label>
        <input type="number" name="release_year" placeholder="2010" required>
        
        <label>Rating</label>
        <input type="number" step="0.1" name="rating" placeholder="8.8" required>
        
        <button type="submit">Add to Library</button>
    </form>
</div>

<hr style="border: 0; border-top: 1px solid var(--border); margin: 50px 0;">

<h3>My Collection</h3>

<table>
    <thead>
        <tr>
            <th style="width: 70px;">ID</th>
            <th>Title</th>
            <th>Director</th>
            <th style="width: 90px;">Year</th>
            <th style="width: 90px;">Rating</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        {{#each movies}}
        <tr>
            <td style="color: var(--text-muted); font-family: monospace;">#{{this.id}}</td>
            <td style="font-weight: 700; color: white;">{{this.title}}</td>
            <td>{{this.director}}</td>
            <td>{{this.release_year}}</td>
            <td style="font-weight: 700; color: #fbbf24;">★ {{this.rating}}</td>
            <td>
                <div class="actions-cell">
                    <a href="/movies/edit/{{this.id}}" class="btn-edit">Edit</a>
                    <form action="/movies/delete/{{this.id}}" method="POST" style="margin: 0; display: flex;">
                        <button type="submit" class="btn-delete">Delete</button>
                    </form>
                </div>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>