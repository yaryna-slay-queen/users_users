<style>
  body {
    background-color: #121212;
    margin: 0;
    padding: 0;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .table-wrapper {
    max-width: 1300px;
    margin: 0 0 0 20px;
    padding: 0 20px;
  }

  .page-title {
    font-weight: 900;
    font-size: 56px;
    text-transform: uppercase;
    letter-spacing: 6px;
    text-align: center;
    margin-bottom: 50px;
    color: #ffffff;
    text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);
    transform: translateX(50px);
  }

  .button-group {
    display: flex;
    gap: 15px; 
    margin-bottom: 30px;
    transform: translateX(0px); 
  }

  .btn-main {
    display: inline-block;
    padding: 18px 36px;
    background-color: #ffffff; 
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 2px;
    border-radius: 6px;
    transition: all 0.3s ease;
    border: 2px solid #ffffff;
    cursor: pointer;
    font-family: inherit; 
  }

  .btn-main:hover {
    background-color: #000000;
    color: #ffffff;
    transform: scale(1.05);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background-color: #1a1c1e;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #333;
  }

  table thead {
    background-color: #000000;
  }

  table th {
    padding: 22px 15px;
    text-align: left;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 2px;
    font-weight: 800;
    color: #ffffff;
    border-bottom: 2px solid #333;
  }

  table td {
    padding: 20px 15px;
    border-bottom: 1px solid #2a2a2a;
    font-size: 16px;
    color: #ffffff !important;
    font-weight: 600;
    vertical-align: middle;
  }

  table tbody th {
    padding: 20px 15px;
    color: #888;
    font-weight: bold;
    text-align: left;
    border-bottom: 1px solid #2a2a2a;
  }

  table tbody tr:hover {
    background-color: #25282b;
  }
</style>

<div class="table-wrapper">
  <h1 class="page-title">Cats</h1>

  <div class="button-group">
    <a href="/" class="btn-main"> <--Back </a>

    <a href="/cats/add" class="btn-main">+ ADD</a>
    
    <button class="btn-main" onclick="handleUpdate()">UPDATE</button>
    
    <button class="btn-main" onclick="handleDelete()">DELETE</button>
  </div>
  <table>
    <thead>
      <tr>
        <th scope="col">id</th>
        <th scope="col">name</th>
        <th scope="col">breed</th>
        <th scope="col">age_years</th>
        <th scope="col">weight_kg</th>
        <th scope="col">favorite_food</th>
        <th scope="col">has_microchip</th>
        <th scope="col">owner_contact</th>
        <th scope="col">character_notes</th>
        <th scope="col">created_at</th>
      </tr>
    </thead>
    <tbody>
      {{#each cats}}
        <tr>
          <th scope="row">{{this.id}}</th>
          <td>{{this.name}}</td>
          <td>{{this.breed}}</td>
          <td>{{this.age_years}}</td>
          <td>{{this.weight_kg}}</td>
          <td>{{this.favorite_food}}</td>
          <td>{{this.has_microchip}}</td>
          <td>{{this.owner_contact}}</td>
          <td>{{this.character_notes}}</td>
          <td>{{this.created_at}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<script>
  function handleUpdate() {
    const id = prompt("Enter the cat ID to edit:");
    if (!id) return; 
    const existingIds = Array.from(document.querySelectorAll('tbody tr th')).map(el => el.innerText.trim());
    if (id && !isNaN(id) && existingIds.includes(id)) {
      window.location.href = "/cats/edit/" + id;
    } else if (id) {
      alert("Error: Cat with ID " + id + " not found in this table!");
    }
  }

  function handleDelete() {
    const id = prompt("Enter the ID of the cat you want to DELETE:");
    if (!id) return;

    const existingIds = Array.from(document.querySelectorAll('tbody tr th')).map(el => el.innerText.trim());

    if (id && !isNaN(id) && existingIds.includes(id)) {
      if (confirm("Are you sure you want to remove the cat from the ID? " + id + "?")) {
        window.location.href = "/cats/delete/" + id;
      }
    } else if (id) {
      alert("Error: Cat with ID " + id + " not found in this table!");
    }
  }
</script>